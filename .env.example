# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="your-gemini-api-key"

# --- Railway (backend) ---
# PORT: Set automatically by Railway
# DATABASE_PATH: For SQLite. Use /data/budget.db if using Railway volume.
# CORS_ORIGIN: Your Vercel frontend URL (e.g. https://your-app.vercel.app) when using split deployment

# --- Vercel (frontend only) ---
# VITE_API_URL: Your Railway backend URL (e.g. https://your-app.railway.app) when frontend is on Vercel
